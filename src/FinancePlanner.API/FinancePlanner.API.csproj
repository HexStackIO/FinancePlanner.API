<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<!-- Enable server garbage collection for better throughput -->
		<ServerGarbageCollection>true</ServerGarbageCollection>
		<!-- Enable concurrent garbage collection -->
		<ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\FinancePlanner.Core\FinancePlanner.Core.csproj" />
		<ProjectReference Include="..\FinancePlanner.Application\FinancePlanner.Application.csproj" />
		<ProjectReference Include="..\FinancePlanner.Infrastructure\FinancePlanner.Infrastructure.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- Core ASP.NET packages - using 8.0 for stability with .NET 10 -->
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.3" />
        <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.*" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.*">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
        <PackageReference Include="Microsoft.Identity.Web" Version="4.4.0" />

		<!-- Swagger -->
        <PackageReference Include="Swashbuckle.AspNetCore" Version="6.*" />

		<!-- Logging -->
        <PackageReference Include="Serilog.AspNetCore" Version="8.0.*" />
        <PackageReference Include="Serilog.Sinks.Console" Version="5.*" />
        <PackageReference Include="Serilog.Sinks.File" Version="5.*" />

        <!-- Performance and caching: Microsoft.Extensions.Caching.Memory is provided by the shared framework; remove explicit package reference -->
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="logs\" />
	</ItemGroup>

</Project>